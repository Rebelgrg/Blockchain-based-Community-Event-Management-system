{
  "name": "event-dapp",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "install:all": "npm install && npm install --prefix web",
    "build": "hardhat compile",
    "clean": "hardhat clean",
    "node": "hardhat node",
    "test": "hardhat test",
    "deploy:local": "hardhat run scripts/deploy.ts --network hardhatMainnet",
    "deploy:sepolia": "hardhat run scripts/deploy.ts --network sepolia",
    "deploy:event:local": "hardhat run scripts/deploy-event-management.ts --network hardhatMainnet",
    "deploy:event:localhost": "hardhat run scripts/deploy-event-management.ts --network localhost",
    "deploy:event:sepolia": "hardhat run scripts/deploy-event-management.ts --network sepolia",
    "ignition:event:localhost": "hardhat ignition deploy ignition/modules/EventManagement.ts --network localhost",
    "web:dev": "npm run dev --prefix web",
    "web:build": "npm run build --prefix web"
  },
